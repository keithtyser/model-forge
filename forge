#!/usr/bin/env bash
set -euo pipefail

REPO_DIR=$(cd "$(dirname "$0")" && pwd)
cd "$REPO_DIR"

PYTHON=${PYTHON:-$REPO_DIR/.venv/bin/python}
if [[ ! -x "$PYTHON" ]]; then
  PYTHON=$(command -v python3)
fi

usage() {
  cat <<'USAGE'
Usage:
  ./forge setup [base|external|artifacts|all]
  ./forge download <family> [base|ft|abli|all]
  ./forge serve <family> [base|ft|abli|local_abli|local_abli_sota|local_abli_huihui_like|local_abli_huihui_like_s4]
  ./forge eval <family> [base|ft|abli|local_abli|local_abli_sota|local_abli_huihui_like|local_abli_huihui_like_s4] [--smoke|--internal|--artifact|--external] [tasks]
  ./forge external <family> [base|ft|abli|local_abli|local_abli_sota|local_abli_huihui_like|local_abli_huihui_like_s4] [tasks]
  ./forge ablate <family> [plan|collect|analyze-reference|sweep-reference|export|sota-plan|sota-prepare|sota-run] [--execute]
  ./forge compare <family>
  ./forge golden-summary <family> [output-json]
  ./forge golden-check <family> [baseline-json]
  ./forge families

Examples:
  ./forge setup all
  ./forge download gemma4_26b_a4b all
  ./forge serve gemma4_26b_a4b base
  ./forge eval gemma4_26b_a4b base
  ./forge ablate gemma4_26b_a4b plan
  ./forge compare gemma4_26b_a4b

By default, eval runs internal checks, artifact evals, external benchmarks,
and refreshes the comparison report for the requested served variant.
USAGE
}

ACTION=${1:-help}
shift || true

case "$ACTION" in
  setup)
    ./scripts/setup.sh "${1:-base}"
    ;;
  download)
    FAMILY=${1:?family is required}
    VARIANT=${2:-all}
    "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" download "$VARIANT"
    ;;
  serve)
    FAMILY=${1:?family is required}
    VARIANT=${2:-base}
    "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" serve "$VARIANT"
    ;;
  eval)
    FAMILY=${1:?family is required}
    VARIANT=${2:-base}
    MODE=${3:-suite}
    TASKS=${4:-}
    case "$MODE" in
      --smoke|smoke) MODE=smoke ;;
      --internal|--full|internal|full) MODE=full ;;
      --artifact|artifact) MODE=artifact ;;
      --external|external) MODE=external ;;
      suite|all|"") MODE=suite ;;
      *) echo "unknown eval mode: $MODE" >&2; usage >&2; exit 2 ;;
    esac
    if [[ "$MODE" == "suite" || "$MODE" == "external" ]] && [[ -n "$TASKS" ]]; then
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" "$MODE" "$VARIANT" "$TASKS"
    else
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" "$MODE" "$VARIANT"
    fi
    ;;
  external)
    FAMILY=${1:?family is required}
    VARIANT=${2:-base}
    TASKS=${3:-}
    if [[ -n "$TASKS" ]]; then
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" external "$VARIANT" "$TASKS"
    else
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" external "$VARIANT"
    fi
    ;;
  ablate)
    FAMILY=${1:?family is required}
    shift
    STEP=${1:-plan}
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "$FAMILY" in
      gemma4_26b_a4b)
        CONFIG="$REPO_DIR/configs/abliteration/gemma4_26b_a4b_local_abli.yaml"
        ;;
      *) echo "unknown ablation family: $FAMILY" >&2; exit 2 ;;
    esac
    "$PYTHON" -m model_forge.pipelines.abliterate --config "$CONFIG" "$STEP" "$@"
    ;;
  compare)
    FAMILY=${1:?family is required}
    "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" compare
    ;;
  golden-summary)
    FAMILY=${1:?family is required}
    OUTPUT=${2:-}
    case "$FAMILY" in
      gemma4_26b_a4b)
        COMPARISON="$REPO_DIR/reports/generated/gemma4_26b_a4b_comparison/comparison.json"
        DEFAULT_OUTPUT="$REPO_DIR/reports/golden/gemma4_26b_a4b_ablation_internal.json"
        ;;
      *) echo "unknown golden summary family: $FAMILY" >&2; exit 2 ;;
    esac
    "$PYTHON" -m model_forge.evals.golden_summary \
      --comparison "$COMPARISON" \
      --output "${OUTPUT:-$DEFAULT_OUTPUT}" \
      --objective ablation_research
    ;;
  golden-check)
    FAMILY=${1:?family is required}
    BASELINE=${2:-}
    case "$FAMILY" in
      gemma4_26b_a4b)
        COMPARISON="$REPO_DIR/reports/generated/gemma4_26b_a4b_comparison/comparison.json"
        DEFAULT_BASELINE="$REPO_DIR/reports/golden/gemma4_26b_a4b_ablation_internal.json"
        ;;
      *) echo "unknown golden summary family: $FAMILY" >&2; exit 2 ;;
    esac
    "$PYTHON" -m model_forge.evals.golden_summary \
      --comparison "$COMPARISON" \
      --check "${BASELINE:-$DEFAULT_BASELINE}" \
      --objective ablation_research
    ;;
  families)
    find "$REPO_DIR/configs/model_families" -maxdepth 1 -name '*.yaml' -printf '%f\n' | sed 's/[.]yaml$//' | sort
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "unknown command: $ACTION" >&2
    usage >&2
    exit 2
    ;;
esac

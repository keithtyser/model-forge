  ./forge hf [status|login|whoami|plan-model|publish-model|publish-dataset|release-classes]
  ./forge variants [graph|node|audit-node|tokenizer-audit|architecture-audit|checkpoint-audit]
  ./forge manifest [write|show]
  ./forge artifacts [validate]
  ./forge bench [serve|serve-eval|sweep|kernel]
  ./forge profile [nsight]
  ./forge quantize [plan|export|calibration-manifest|matrix-plan|card|fp8-kv-report|behavior-report|tokenizer-report|sensitivity-report|nvfp4-gate]
  ./forge cluster [plan|doctor|sync|health|runtime|torchrun-smoke]
  ./forge golden-summary <family> [output-json]
  ./forge golden-check <family> [baseline-json]
  ./forge doctor [--json]
  ./forge families

Examples:
  ./forge setup all
  ./forge download gemma4_26b_a4b all
  ./forge serve gemma4_26b_a4b base
  ./forge serving plan --config configs/serving/backends/sglang_openai.yaml --family gemma4_26b_a4b --variant base --write-plan
  ./forge serving plan --config configs/serving/backends/tensorrt_llm_openai.yaml --family gemma4_26b_a4b --variant base --write-plan
  ./forge serving architecture-doctor --config configs/serving/architectures/distributed_kv_placeholder.yaml --strict
  ./forge bench sweep plan --config configs/sweeps/dgx_spark_vllm_disagg_prefill_decode.yaml --family gemma4_26b_a4b --variant base --cluster-config configs/clusters/dgx_spark_x2.example.yaml
  ./forge serve-teacher qwen35_9b
  ./forge eval gemma4_26b_a4b base
  ./forge finetune gemma4_26b_a4b plan
  ./forge finetune --config configs/finetuning/gemma4_26b_a4b_local_ft_v1_dryrun.yaml plan
  ./forge data plan gemma4_26b_a4b local_ft_v1
  ./forge data propose gemma4_26b_a4b local_ft_v1
  ./forge data training-gate gemma4_26b_a4b local_ft_v1 --finetune-plan <run>/plan.json --data-summary <run>/data_summary.json --promotion-report <promotion>.json --write-gate
  ./forge ablate gemma4_26b_a4b plan
  ./forge compare gemma4_26b_a4b
  ./forge behavior score --config configs/behavior_edit/gemma4_26b_a4b_scorecard.yaml local_abli_sota_vs_base --write-card
  ./forge behavior frontier --config configs/behavior_edit/gemma4_26b_a4b_scorecard.yaml local_abli_sota_vs_base --write-report
  ./forge behavior risk-report --config configs/behavior_edit/gemma4_26b_a4b_scorecard.yaml local_abli_sota_vs_base --write-report
  ./forge promote gemma4_26b_a4b local_ft_vs_jackrong
  ./forge objectives audit
  ./forge schema audit
  ./forge roadmap audit --write-doc
  ./forge roadmap cli-drift
  ./forge generalization audit
  ./forge agent audit
  ./forge agent card recipes/agents/agent_experiment_template.yaml --write-card --update-ledger
  ./forge agent optimize-serving --family gemma4_26b_a4b --variant base
  ./forge agent optimize-quantization --config configs/quantization/gemma4_26b_a4b_nvfp4_modelopt.yaml --variants base
  ./forge agent optimize-behavior-edit --family gemma4_26b_a4b
  ./forge upstream plan --config configs/upstream/pr_candidates.yaml --candidate dgx_spark_vllm_serving_recipe --write-plan
  ./forge upstream apply-draft --config configs/upstream/pr_candidates.yaml --candidate dgx_spark_vllm_serving_recipe --target-worktree /tmp/model_forge_vllm
  ./forge upstream verify-pr --config configs/upstream/pr_candidates.yaml --candidate dgx_spark_vllm_serving_recipe --offline --write-report
  ./forge research audit
  ./forge research watch
  ./forge hf release-classes --audit
  ./forge hf status
  ./forge hf plan-model gemma4_26b_a4b local_ft --release-class report_only
  ./forge hf publish-dataset datasets/generated/gemma4_26b_a4b_local_ft_v1/hf_publish_bundle --repo-id keithtyser/model-forge-gemma-local-ft-v1 --dry-run
  ./forge variants graph gemma4_26b_a4b
  ./forge variants architecture-audit gemma4_26b_a4b
  ./forge variants tokenizer-audit gemma4_26b_a4b
  ./forge variants checkpoint-audit gemma4_26b_a4b --variant base --strict
  ./forge manifest write --run-type eval --family gemma4_26b_a4b --variant base --command './forge eval gemma4_26b_a4b base --internal'
  ./forge artifacts validate reports/generated/.../artifacts/
  ./forge bench serve --family gemma4_26b_a4b --variant base --dry-run
  ./forge bench serve --evidence-gate --summary reports/generated/serve_bench/<run>/summary.json --serving-eval reports/generated/serve_eval/<run> --write-gate
  ./forge bench serve-eval plan --family gemma4_26b_a4b --variant base
  ./forge bench sweep plan --family gemma4_26b_a4b --variant base
  ./forge bench kernel rmsnorm --dry-run
  ./forge bench kernel rope --dry-run
  ./forge bench kernel dequant --dry-run
  ./forge bench kernel kv-layout --dry-run
  ./forge bench kernel card --summary reports/generated/kernel_benchmarks/<run>/summary.json --write-card
  ./forge profile nsight plan --config configs/profiling/nsight_serving_smoke.yaml
  ./forge profile nsight summarize --plan reports/generated/profiles/nsight/<run>/nsight_profile_plan.json
  ./forge quantize plan --config configs/quantization/nvfp4_blackwell_runtime.yaml --write-plan
  ./forge quantize plan llama31_8b base --config configs/quantization/fp8_w8a8_modelopt.yaml --write-plan
  ./forge quantize export llama31_8b base --config configs/quantization/gguf_llama_cpp_q4_k_m.yaml --write-plan
  ./forge quantize calibration-manifest gemma4_26b_a4b base --config configs/quantization/gemma4_26b_a4b_nvfp4_modelopt.yaml --write-manifest
  ./forge quantize matrix-plan --config configs/quantization/gemma4_26b_a4b_nvfp4_modelopt.yaml
  ./forge quantize fp8-kv-report --config configs/quantization/gemma4_26b_a4b_fp8_runtime.yaml --source-serving-summary <source>/summary.json --candidate-serving-summary <candidate>/summary.json --source-serving-eval <source_eval> --candidate-serving-eval <candidate_eval> --run-id source_vs_fp8_kv --write-report
  ./forge quantize behavior-report --config configs/quantization/fp8_w8a8_modelopt.yaml --source-serving-summary <source>/summary.json --candidate-serving-summary <candidate>/summary.json --source-serving-eval <source_eval> --candidate-serving-eval <candidate_eval> --run-id source_vs_quantized_behavior --write-report
  ./forge quantize tokenizer-report --source-tokenizer-dir <source_model_dir> --candidate-tokenizer-dir <quantized_or_gguf_dir> --run-id source_vs_quantized_tokenizer --write-report
  ./forge quantize sensitivity-report --config configs/quantization/sensitivity_scan.yaml --baseline-serving-summary <source>/summary.json --baseline-serving-eval <source_eval> --candidate name=mlp_only,component=mlp,summary=<candidate>/summary.json,eval=<candidate_eval> --run-id quant_sensitivity --write-report
  ./forge quantize nvfp4-gate --export-plan <export_plan.json> --serving-summary <serve>/summary.json --serving-eval <serve_eval> --quantization-card <quantization_card.json> --behavior-report <behavior_report.json> --tokenizer-report <tokenizer_report.json> --run-id nvfp4_gate --write-gate
  ./forge cluster plan --config configs/clusters/dgx_spark_x2.example.yaml --workload train
  ./forge cluster sync --config configs/clusters/dgx_spark_x2.example.yaml
  ./forge cluster health --config configs/clusters/dgx_spark_x2.example.yaml
  ./forge cluster runtime --config configs/clusters/dgx_spark_x2.example.yaml --image nemotron-runner:latest
  ./forge cluster torchrun-smoke --config configs/clusters/dgx_spark_x2.example.yaml --image nemotron-runner:latest
  ./forge doctor

By default, eval runs internal checks, artifact evals, external benchmarks,
and refreshes the comparison report for the requested served variant.
USAGE
}

ACTION=${1:-help}
shift || true

require_config() {
  local path=$1
  local message=$2
  if [[ ! -f "$path" ]]; then
    echo "$message" >&2
    exit 2
  fi
}

case "$ACTION" in
  setup)
    ./scripts/setup.sh "${1:-base}"
    ;;
  download)
    FAMILY=${1:?family is required}
    VARIANT=${2:-all}
    "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" download "$VARIANT"
    ;;
  serve)
    FAMILY=${1:?family is required}
    VARIANT=${2:-base}
    "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" serve "$VARIANT"
    ;;
  serving)
    "$PYTHON" -m model_forge.serving.backends "$@"
    ;;
  serve-teacher)
    TEACHER=${1:-${MODEL_FORGE_TEACHER_FAMILY:-qwen35_9b}}
    TEACHER_CONFIG="$REPO_DIR/configs/model_families/${TEACHER}.yaml"
    require_config "$TEACHER_CONFIG" "missing teacher family config: configs/model_families/${TEACHER}.yaml"
    eval "$("$PYTHON" - "$REPO_DIR" "$TEACHER" <<'PY'
import os
import shlex
import sys
from pathlib import Path

import yaml

repo = Path(sys.argv[1])
family_name = sys.argv[2]
family = yaml.safe_load((repo / "configs" / "model_families" / f"{family_name}.yaml").read_text()) or {}
teacher = family.get("teacher") or {}
if not teacher:
    raise SystemExit(f"family {family_name!r} has no teacher block")
variant_name = str(teacher.get("variant") or "base")
variant = (family.get("variants") or {}).get(variant_name) or {}
if not variant:
    raise SystemExit(f"family {family_name!r} has no teacher variant {variant_name!r}")
env_name = str(family.get("models_dir_env") or "MODEL_FORGE_MODELS_DIR")
models_dir = Path(os.environ.get(env_name) or family.get("default_models_dir") or "~/models").expanduser()
local_dir = Path(str(variant.get("local_dir") or "")).expanduser()
model_path = local_dir if local_dir.is_absolute() else models_dir / local_dir
script = repo / str(teacher.get("script") or "scripts/serve_teacher_vllm_dgx_spark.sh")
chat_template = (family.get("architecture") or {}).get("chat_template") or {}
assignments = {
    "MODEL_FORGE_TEACHER_SCRIPT": str(script),
    "MODEL_FORGE_TEACHER_MODEL": str(model_path),
    "MODEL_FORGE_TEACHER_NAME": str(teacher.get("served_model_name") or variant.get("served_model_name") or variant.get("repo_id")),
    "PORT": str(teacher.get("port") or 8011),
}
if chat_template.get("reasoning_parser"):
    assignments["MODEL_FORGE_TEACHER_REASONING_PARSER"] = str(chat_template["reasoning_parser"])
if chat_template.get("default_chat_template_kwargs") is not None:
    import json
    assignments["MODEL_FORGE_TEACHER_CHAT_TEMPLATE_KWARGS"] = json.dumps(chat_template["default_chat_template_kwargs"])
for key, value in assignments.items():
    print(f"export {key}={shlex.quote(value)}")
PY
)"
    require_config "$MODEL_FORGE_TEACHER_SCRIPT" "missing teacher launcher: $MODEL_FORGE_TEACHER_SCRIPT"
    exec "$MODEL_FORGE_TEACHER_SCRIPT"
    ;;
  eval)
    FAMILY=${1:?family is required}
    VARIANT=${2:-base}
    MODE=${3:-suite}
    TASKS=${4:-}
    case "$MODE" in
      --smoke|smoke) MODE=smoke ;;
      --internal|--full|internal|full) MODE=full ;;
      --artifact|artifact) MODE=artifact ;;
      --external|external) MODE=external ;;
      suite|all|"") MODE=suite ;;
      *) echo "unknown eval mode: $MODE" >&2; usage >&2; exit 2 ;;
    esac
    if [[ "$MODE" == "suite" || "$MODE" == "external" ]] && [[ -n "$TASKS" ]]; then
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" "$MODE" "$VARIANT" "$TASKS"
    else
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" "$MODE" "$VARIANT"
    fi
    ;;
  external)
    FAMILY=${1:?family is required}
    VARIANT=${2:-base}
    TASKS=${3:-}
    if [[ -n "$TASKS" ]]; then
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" external "$VARIANT" "$TASKS"
    else
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" external "$VARIANT"
    fi
    ;;
  finetune)
    FAMILY=${1:?family is required}
    shift
    case "$FAMILY" in
      --config)
        CONFIG=${1:?config path is required after --config}
        shift
        STEP=${1:-plan}
        if [[ $# -gt 0 ]]; then
          shift
        fi
        ;;
      *)
        STEP=${1:-plan}
        if [[ $# -gt 0 ]]; then
          shift
        fi
        CONFIG="$REPO_DIR/configs/finetuning/${FAMILY}_local_ft_v0.yaml"
        require_config "$CONFIG" "missing fine-tune config for family '$FAMILY': configs/finetuning/${FAMILY}_local_ft_v0.yaml"
        ;;
    esac
    "$PYTHON" -m model_forge.pipelines.finetune --config "$CONFIG" "$STEP" "$@"
    ;;
  data)
    STEP=${1:-plan}
    FAMILY=${2:?family is required}
    VARIANT=${3:?variant is required}
    shift 3 || true
    "$PYTHON" -m model_forge.data.factory "$STEP" "$FAMILY" "$VARIANT" "$@"
    ;;
  ablate)
    FAMILY=${1:?family is required}
    shift
    case "$FAMILY" in
      --config)
        CONFIG=${1:?config path is required after --config}
        shift
        STEP=${1:-plan}
        if [[ $# -gt 0 ]]; then
          shift
        fi
        require_config "$CONFIG" "missing ablation config: $CONFIG"
        ;;
      *)
        STEP=${1:-plan}
        if [[ $# -gt 0 ]]; then
          shift
        fi
        CONFIG="$REPO_DIR/configs/abliteration/${FAMILY}_local_abli.yaml"
        require_config "$CONFIG" "missing ablation config for family '$FAMILY': configs/abliteration/${FAMILY}_local_abli.yaml"
        ;;
    esac
    "$PYTHON" -m model_forge.pipelines.abliterate --config "$CONFIG" "$STEP" "$@"
    ;;
  compare)
    FAMILY=${1:?family is required}
    "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" compare
    ;;
  behavior)
    "$PYTHON" -m model_forge.evals.behavior_scorecard "$@"
    ;;
  promote)
    FAMILY=${1:?family is required}
    PROFILE=${2:-}
    CONFIG="$REPO_DIR/configs/promotion/${FAMILY}.yaml"
    require_config "$CONFIG" "missing promotion config for family '$FAMILY': configs/promotion/${FAMILY}.yaml"
    if [[ -n "$PROFILE" ]]; then
      "$PYTHON" -m model_forge.evals.promotion --config "$CONFIG" "$PROFILE"
    else
      "$PYTHON" -m model_forge.evals.promotion --config "$CONFIG"
    fi
    ;;
  research)
    "$PYTHON" -m model_forge.research.registry "$@"
    ;;
  hf)
    "$PYTHON" -m model_forge.hub.cli "$@"
    ;;
  variants)
    "$PYTHON" -m model_forge.variants.cli "$@"
    ;;
  objectives)
    "$PYTHON" -m model_forge.objectives "$@"
    ;;
  schema)
    "$PYTHON" -m model_forge.schema_audit "$@"
    ;;
  roadmap)
    "$PYTHON" -m model_forge.roadmap "$@"
    ;;
  generalization)
    "$PYTHON" -m model_forge.generalization "$@"
    ;;
  agent)
    "$PYTHON" -m model_forge.agents "$@"
    ;;
  upstream)
    "$PYTHON" -m model_forge.upstream "$@"
    ;;
  manifest)
    "$PYTHON" -m model_forge.runs.manifest "$@"
    ;;
  artifacts)
    "$PYTHON" -m model_forge.artifacts.validate "$@"
    ;;
  bench)
    BENCH=${1:-}
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "$BENCH" in
      serve)
        "$PYTHON" -m model_forge.benchmarks.serve "$@"
        ;;
      serve-eval)
        "$PYTHON" -m model_forge.benchmarks.serve_eval "$@"
        ;;
      sweep)
        "$PYTHON" -m model_forge.benchmarks.sweep "$@"
        ;;
      kernel)
        "$PYTHON" -m model_forge.benchmarks.kernel "$@"
        ;;
      *) echo "unknown benchmark: ${BENCH:-}" >&2; usage >&2; exit 2 ;;
    esac
    ;;
  profile)
    PROFILE=${1:-}
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "$PROFILE" in
      nsight)
        "$PYTHON" -m model_forge.profiling.nsight "$@"
        ;;
      *) echo "unknown profile command: ${PROFILE:-}" >&2; usage >&2; exit 2 ;;
    esac
    ;;
  quantize)
    "$PYTHON" -m model_forge.quantization.cli "$@"
    ;;
  cluster)
    "$PYTHON" -m model_forge.cluster.cli "$@"
    ;;
  golden-summary)
    FAMILY=${1:?family is required}
    OUTPUT=${2:-}
    COMPARISON="$REPO_DIR/reports/generated/${FAMILY}_comparison/comparison.json"
    DEFAULT_OUTPUT="$REPO_DIR/reports/golden/${FAMILY}_ablation_internal.json"
    "$PYTHON" -m model_forge.evals.golden_summary \
      --comparison "$COMPARISON" \
      --output "${OUTPUT:-$DEFAULT_OUTPUT}" \
      --objective ablation_research
    ;;
  golden-check)
    FAMILY=${1:?family is required}
    BASELINE=${2:-}
    COMPARISON="$REPO_DIR/reports/generated/${FAMILY}_comparison/comparison.json"
    DEFAULT_BASELINE="$REPO_DIR/reports/golden/${FAMILY}_ablation_internal.json"
    "$PYTHON" -m model_forge.evals.golden_summary \
      --comparison "$COMPARISON" \
      --check "${BASELINE:-$DEFAULT_BASELINE}" \
      --objective ablation_research
    ;;
  doctor)
    "$PYTHON" -m model_forge.doctor "$@"
    ;;
  families)
    find "$REPO_DIR/configs/model_families" -maxdepth 1 -name '*.yaml' -printf '%f\n' | sed 's/[.]yaml$//' | sort
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "unknown command: $ACTION" >&2
    usage >&2
    exit 2
    ;;
esac

#!/usr/bin/env bash
set -euo pipefail

REPO_DIR=$(cd "$(dirname "$0")" && pwd)
cd "$REPO_DIR"

PYTHON=${PYTHON:-$REPO_DIR/.venv/bin/python}
if [[ ! -x "$PYTHON" ]]; then
  PYTHON=$(command -v python3)
fi

usage() {
  cat <<'USAGE'
Usage:
  ./forge setup [base|external|artifacts|all]
  ./forge download <family> [base|ft|abli|all]
  ./forge serve <family> [variant]
  ./forge serve-teacher [qwen35_9b]
  ./forge eval <family> [variant] [--smoke|--internal|--artifact|--external] [tasks]
  ./forge external <family> [variant] [tasks]
  ./forge finetune <family> [plan|prepare|run] [--execute]
  ./forge finetune --config <path> [plan|prepare|run]
  ./forge data [plan|gaps|seed|generate|judge|verify|filter|review|pack|publish] <family> <variant> [--overwrite] [--smoke]
  ./forge ablate <family> [plan|collect|analyze-reference|sweep-reference|export|sota-plan|sota-prepare|sota-run] [--execute]
  ./forge compare <family>
  ./forge promote <family> [profile]
  ./forge objectives [list|show|audit]
  ./forge roadmap [audit|cli-drift]
  ./forge research [list|show|audit]
  ./forge variants [graph|node|audit-node]
  ./forge manifest [write|show]
  ./forge bench [serve|serve-eval|sweep]
  ./forge quantize [plan|export|matrix-plan|card]
  ./forge cluster [plan|doctor|sync|health|runtime]
  ./forge golden-summary <family> [output-json]
  ./forge golden-check <family> [baseline-json]
  ./forge doctor [--json]
  ./forge families

Examples:
  ./forge setup all
  ./forge download gemma4_26b_a4b all
  ./forge serve gemma4_26b_a4b base
  ./forge serve-teacher qwen35_9b
  ./forge eval gemma4_26b_a4b base
  ./forge finetune gemma4_26b_a4b plan
  ./forge finetune --config configs/finetuning/gemma4_26b_a4b_local_ft_v1_dryrun.yaml plan
  ./forge data plan gemma4_26b_a4b local_ft_v1
  ./forge ablate gemma4_26b_a4b plan
  ./forge compare gemma4_26b_a4b
  ./forge promote gemma4_26b_a4b local_ft_vs_jackrong
  ./forge objectives audit
  ./forge roadmap audit --write-doc
  ./forge roadmap cli-drift
  ./forge research audit
  ./forge variants graph gemma4_26b_a4b
  ./forge manifest write --run-type eval --family gemma4_26b_a4b --variant base --command './forge eval gemma4_26b_a4b base --internal'
  ./forge bench serve --family gemma4_26b_a4b --variant base --dry-run
  ./forge bench serve-eval plan --family gemma4_26b_a4b --variant base
  ./forge bench sweep plan --family gemma4_26b_a4b --variant base
  ./forge quantize plan --config configs/quantization/nvfp4_blackwell_runtime.yaml --write-plan
  ./forge quantize matrix-plan --config configs/quantization/gemma4_26b_a4b_nvfp4_modelopt.yaml
  ./forge cluster plan --config configs/clusters/dgx_spark_x2.example.yaml --workload train
  ./forge cluster sync --config configs/clusters/dgx_spark_x2.example.yaml
  ./forge cluster health --config configs/clusters/dgx_spark_x2.example.yaml
  ./forge cluster runtime --config configs/clusters/dgx_spark_x2.example.yaml --image nemotron-runner:latest
  ./forge doctor

By default, eval runs internal checks, artifact evals, external benchmarks,
and refreshes the comparison report for the requested served variant.
USAGE
}

ACTION=${1:-help}
shift || true

case "$ACTION" in
  setup)
    ./scripts/setup.sh "${1:-base}"
    ;;
  download)
    FAMILY=${1:?family is required}
    VARIANT=${2:-all}
    "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" download "$VARIANT"
    ;;
  serve)
    FAMILY=${1:?family is required}
    VARIANT=${2:-base}
    "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" serve "$VARIANT"
    ;;
  serve-teacher)
    TEACHER=${1:-qwen35_9b}
    case "$TEACHER" in
      qwen35_9b)
        exec "$REPO_DIR/scripts/serve_teacher_vllm_dgx_spark.sh"
        ;;
      *) echo "unknown teacher preset: $TEACHER" >&2; exit 2 ;;
    esac
    ;;
  eval)
    FAMILY=${1:?family is required}
    VARIANT=${2:-base}
    MODE=${3:-suite}
    TASKS=${4:-}
    case "$MODE" in
      --smoke|smoke) MODE=smoke ;;
      --internal|--full|internal|full) MODE=full ;;
      --artifact|artifact) MODE=artifact ;;
      --external|external) MODE=external ;;
      suite|all|"") MODE=suite ;;
      *) echo "unknown eval mode: $MODE" >&2; usage >&2; exit 2 ;;
    esac
    if [[ "$MODE" == "suite" || "$MODE" == "external" ]] && [[ -n "$TASKS" ]]; then
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" "$MODE" "$VARIANT" "$TASKS"
    else
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" "$MODE" "$VARIANT"
    fi
    ;;
  external)
    FAMILY=${1:?family is required}
    VARIANT=${2:-base}
    TASKS=${3:-}
    if [[ -n "$TASKS" ]]; then
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" external "$VARIANT" "$TASKS"
    else
      "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" external "$VARIANT"
    fi
    ;;
  finetune)
    FAMILY=${1:?family is required}
    shift
    case "$FAMILY" in
      --config)
        CONFIG=${1:?config path is required after --config}
        shift
        STEP=${1:-plan}
        if [[ $# -gt 0 ]]; then
          shift
        fi
        ;;
      gemma4_26b_a4b)
        STEP=${1:-plan}
        if [[ $# -gt 0 ]]; then
          shift
        fi
        CONFIG="$REPO_DIR/configs/finetuning/gemma4_26b_a4b_local_ft_v0.yaml"
        ;;
      *) echo "unknown fine-tune family: $FAMILY" >&2; exit 2 ;;
    esac
    "$PYTHON" -m model_forge.pipelines.finetune --config "$CONFIG" "$STEP" "$@"
    ;;
  data)
    STEP=${1:-plan}
    FAMILY=${2:?family is required}
    VARIANT=${3:?variant is required}
    shift 3 || true
    "$PYTHON" -m model_forge.data.factory "$STEP" "$FAMILY" "$VARIANT" "$@"
    ;;
  ablate)
    FAMILY=${1:?family is required}
    shift
    STEP=${1:-plan}
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "$FAMILY" in
      gemma4_26b_a4b)
        CONFIG="$REPO_DIR/configs/abliteration/gemma4_26b_a4b_local_abli.yaml"
        ;;
      *) echo "unknown ablation family: $FAMILY" >&2; exit 2 ;;
    esac
    "$PYTHON" -m model_forge.pipelines.abliterate --config "$CONFIG" "$STEP" "$@"
    ;;
  compare)
    FAMILY=${1:?family is required}
    "$PYTHON" "$REPO_DIR/scripts/model_forge_dgx.py" "$FAMILY" compare
    ;;
  promote)
    FAMILY=${1:?family is required}
    PROFILE=${2:-}
    case "$FAMILY" in
      gemma4_26b_a4b)
        CONFIG="$REPO_DIR/configs/promotion/gemma4_26b_a4b.yaml"
        ;;
      *) echo "unknown promotion family: $FAMILY" >&2; exit 2 ;;
    esac
    if [[ -n "$PROFILE" ]]; then
      "$PYTHON" -m model_forge.evals.promotion --config "$CONFIG" "$PROFILE"
    else
      "$PYTHON" -m model_forge.evals.promotion --config "$CONFIG"
    fi
    ;;
  research)
    "$PYTHON" -m model_forge.research.registry "$@"
    ;;
  variants)
    "$PYTHON" -m model_forge.variants.cli "$@"
    ;;
  objectives)
    "$PYTHON" -m model_forge.objectives "$@"
    ;;
  roadmap)
    "$PYTHON" -m model_forge.roadmap "$@"
    ;;
  manifest)
    "$PYTHON" -m model_forge.runs.manifest "$@"
    ;;
  bench)
    BENCH=${1:-}
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "$BENCH" in
      serve)
        "$PYTHON" -m model_forge.benchmarks.serve "$@"
        ;;
      serve-eval)
        "$PYTHON" -m model_forge.benchmarks.serve_eval "$@"
        ;;
      sweep)
        "$PYTHON" -m model_forge.benchmarks.sweep "$@"
        ;;
      *) echo "unknown benchmark: ${BENCH:-}" >&2; usage >&2; exit 2 ;;
    esac
    ;;
  quantize)
    "$PYTHON" -m model_forge.quantization.cli "$@"
    ;;
  cluster)
    "$PYTHON" -m model_forge.cluster.cli "$@"
    ;;
  golden-summary)
    FAMILY=${1:?family is required}
    OUTPUT=${2:-}
    case "$FAMILY" in
      gemma4_26b_a4b)
        COMPARISON="$REPO_DIR/reports/generated/gemma4_26b_a4b_comparison/comparison.json"
        DEFAULT_OUTPUT="$REPO_DIR/reports/golden/gemma4_26b_a4b_ablation_internal.json"
        ;;
      *) echo "unknown golden summary family: $FAMILY" >&2; exit 2 ;;
    esac
    "$PYTHON" -m model_forge.evals.golden_summary \
      --comparison "$COMPARISON" \
      --output "${OUTPUT:-$DEFAULT_OUTPUT}" \
      --objective ablation_research
    ;;
  golden-check)
    FAMILY=${1:?family is required}
    BASELINE=${2:-}
    case "$FAMILY" in
      gemma4_26b_a4b)
        COMPARISON="$REPO_DIR/reports/generated/gemma4_26b_a4b_comparison/comparison.json"
        DEFAULT_BASELINE="$REPO_DIR/reports/golden/gemma4_26b_a4b_ablation_internal.json"
        ;;
      *) echo "unknown golden summary family: $FAMILY" >&2; exit 2 ;;
    esac
    "$PYTHON" -m model_forge.evals.golden_summary \
      --comparison "$COMPARISON" \
      --check "${BASELINE:-$DEFAULT_BASELINE}" \
      --objective ablation_research
    ;;
  doctor)
    "$PYTHON" -m model_forge.doctor "$@"
    ;;
  families)
    find "$REPO_DIR/configs/model_families" -maxdepth 1 -name '*.yaml' -printf '%f\n' | sed 's/[.]yaml$//' | sort
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "unknown command: $ACTION" >&2
    usage >&2
    exit 2
    ;;
esac
